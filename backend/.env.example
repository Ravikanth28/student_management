# ─── Server ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed frontend origins (no wildcard in production).
# Include your deployed web URL, and for the Android app add https://localhost
# (the Capacitor WebView origin), e.g.:
#   CORS_ORIGIN=https://portal.yourschool.com,https://localhost
CORS_ORIGIN=http://localhost:5173

# ─── JWT ─────────────────────────────────────────────────────
# Generate a strong secret, e.g.:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-32+-char-secret
JWT_EXPIRES_IN=8h

# ─── Database (TiDB / MySQL) ─────────────────────────────────
# Either provide a full connection URL...
TIDB_URL=mysql://user:password@host:4000/student_portal
# ...or the individual fields (used only when TIDB_URL is unset):
# DB_HOST=
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=

# ─── Admin credentials ───────────────────────────────────────
ADMIN_USERNAME=admin
# DEV ONLY — plaintext login. Do NOT set in production.
ADMIN_PASSWORD=change-me
# PRODUCTION — bcrypt hash of the admin password (required in production).
# Generate: node -e "console.log(require('bcrypt').hashSync('yourpassword',12))"
# ADMIN_PASSWORD_HASH=

# ─── Cloudinary (optional — photo uploads) ───────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# ─── Google Drive photo import (optional) ────────────────────
GOOGLE_API_KEY=
