# Base URL of the backend API.
#  - Web dev:      leave as-is (Vite proxies /api → localhost:4000)
#  - Android APK:  MUST be your deployed HTTPS backend, e.g. https://api.yourschool.com
VITE_API_BASE_URL=http://localhost:4000

# Public URL where the built Android APK can be downloaded (shows a "Download App"
# button in the web UI). After GitHub Actions publishes it, this is:
#   https://github.com/<OWNER>/<REPO>/releases/download/apk-latest/student-portal.apk
VITE_APK_URL=
